# User and group IDs for file permissions inside containers.
# Run: id $USER
PUID=1001
PGID=1001

# Timezone for scheduling (Sonarr/Radarr release times).
# Brasília, Brazil (UTC-3)
TZ=America/Sao_Paulo

# Plex claim token — required for first-time server setup.
# Generate at https://www.plex.tv/claim (expires in ~4 minutes).
PLEX_CLAIM=claim-xxxxxxxxxxxxxxxxxxxx

# qBittorrent web UI port (default 8080 conflicts with many apps).
WEBUI_PORT=8082

# Common credentials for all web UIs (*Arr, qBittorrent, Jellyfin, Seerr).
COMMON_USER=admin
COMMON_PASSWORD=your-secure-password

# qBittorrent Web UI credentials.
QBITTORRENT_USER=${COMMON_USER}
QBITTORRENT_PASSWORD=${COMMON_PASSWORD}

# BitTorrent peer connection port (TCP + UDP).
QBITTORRENT_PEER_PORT=6881

# Jellyfin admin credentials (used by Seerr and automation scripts).
JELLYFIN_ADMIN_USER=${COMMON_USER}
JELLYFIN_ADMIN_PASSWORD=${COMMON_PASSWORD}
JELLYFIN_ADMIN_EMAIL=${COMMON_USER}@local

# Seerr admin credentials (used after first setup).
SEERR_ADMIN_EMAIL=${COMMON_USER}@local
SEERR_ADMIN_PASSWORD=${COMMON_PASSWORD}

# Web UI ports for *Arr services (optional overrides).
SONARR_PORT=8989
RADARR_PORT=7878
PROWLARR_PORT=9696

# Jellyfin media server (free remote streaming).
JELLYFIN_PORT=8096
JELLYFIN_DISCOVERY_PORT=7359
# Optional: public URL for remote clients (e.g. http://your-server-ip:8096).
JELLYFIN_PUBLISHED_SERVER_URL=
